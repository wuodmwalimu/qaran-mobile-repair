<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title><%= title %></title>
    
    <!-- Preconnect for faster font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Favicon (placeholder - replace later) -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="logo-container">
                <!-- Logo placeholder - replace src with your logo path later -->
                <div class="logo-placeholder" id="logoPlaceholder">
                    <img src="/images/logo-placeholder.svg" alt="Qaran Mobile Logo" class="logo-image" style="display: none;">
                    <div class="logo-fallback">
                        <i class="fas fa-tools"></i>
                    </div>
                </div>
                <div class="brand-text">
                    <h1>Ramaphosa Mobile</h1>
                    <p>Repair & Accessories</p>
                </div>
            </div>
            
            <!-- Desktop Navigation -->
            <ul class="nav-links">
                <li><a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">Home</a></li>
                <li><a href="/services" class="<%= currentPage === 'services' ? 'active' : '' %>">Services</a></li>
                <li><a href="/accessories" class="<%= currentPage === 'accessories' ? 'active' : '' %>">Accessories</a></li>
                <li><a href="/contact" class="<%= currentPage === 'contact' ? 'active' : '' %>">Contact</a></li>
            </ul>
            
            <!-- Contact Info (Desktop) -->
            <div class="nav-contact">
                <a href="tel:+254723725767" class="nav-phone">
                    <i class="fas fa-phone-alt"></i>
                    <span>+254 723 725 767</span>
                </a>
            </div>
            
            <!-- Mobile Menu Button -->
            <div class="hamburger" id="hamburgerMenu">
                <i class="fas fa-bars"></i>
            </div>
        </nav>
        
        <!-- Mobile Navigation Menu -->
        <div class="mobile-menu" id="mobileMenu">
            <ul class="mobile-nav-links">
                <li><a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">Home</a></li>
                <li><a href="/services" class="<%= currentPage === 'services' ? 'active' : '' %>">Services</a></li>
                <li><a href="/accessories" class="<%= currentPage === 'accessories' ? 'active' : '' %>">Accessories</a></li>
                <li><a href="/contact" class="<%= currentPage === 'contact' ? 'active' : '' %>">Contact</a></li>
                <li class="mobile-divider"></li>
                <li class="mobile-phone">
                    <a href="tel:+254712345678">
                        <i class="fas fa-phone-alt"></i> Call Us: +254 712 345 678
                    </a>
                </li>
                <li class="mobile-whatsapp">
                    <a href="https://wa.me/254712345678" target="_blank">
                        <i class="fab fa-whatsapp"></i> WhatsApp Us
                    </a>
                </li>
            </ul>
        </div>
    </header>
    
    <!-- Overlay for mobile menu -->
    <div class="menu-overlay" id="menuOverlay"></div>
    
    <main>