<%- include('partials/header') %>

<section class="page-header">
    <h1>Mobile Accessories</h1>
    <p>High-quality accessories for all phone models</p>
</section>

<section class="accessories-grid">

    <div class="accessory-card">
        <div class="accessory-image">
            <i class="fas fa-mobile-alt"></i>
        </div>
        <h3>Phone Cases</h3>
        <p>Protective cases for all models</p>
        <p class="price">From KSh 200</p>
        <button class="btn-small">View Options</button>
    </div>

    <div class="accessory-card">
        <div class="accessory-image">
            <i class="fas fa-bolt"></i>
        </div>
        <h3>Chargers & Cables</h3>
        <p>Fast charging cables and adapters</p>
        <p class="price">From KSh 150</p>
        <button class="btn-small">View Options</button>
    </div>

    <div class="accessory-card">
        <div class="accessory-image">
            <i class="fas fa-headphones"></i>
        </div>
        <h3>Headphones</h3>
        <p>Wireless and wired options</p>
        <p class="price">From KSh 150</p>
        <button class="btn-small">View Options</button>
    </div>

    <div class="accessory-card">
        <div class="accessory-image">
            <i class="fas fa-shield-alt"></i>
        </div>
        <h3>Screen Protectors</h3>
        <p>Tempered glass and film protectors</p>
        <p class="price">From KSh 1,000</p>
        <button class="btn-small">View Options</button>
    </div>

    <div class="accessory-card">
        <div class="accessory-image">
            <i class="fas fa-power-off"></i>
        </div>
        <h3>Power Banks</h3>
        <p>Portable chargers for on-the-go</p>
        <p class="price">From KSh 500</p>
        <button class="btn-small">View Options</button>
    </div>

</section>

<%- include('partials/footer') %>